# --- Self-hosted PostgreSQL (use one approach) ---

# Option A: single connection URL (matches your existing Postgres user/db/host)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/tourism_discovery?schema=public"

# Option B: discrete settings (passwords with special chars are easier here)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=tourism_discovery
# POSTGRES_SCHEMA=public

# TLS for remote self-hosted instances (optional)
# POSTGRES_SSL=require
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# AI provider: openai | anthropic | google
AI_PROVIDER=openai

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_MODEL=gemini-2.0-flash
